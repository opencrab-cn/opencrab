{
  "name": "opencrab",
  "version": "0.1.0",
  "description": "AI Agent 桌面框架 - 专为中文用户打造",
  "main": "dist/main/electron.main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "cross-env NODE_ENV=development tsc -p tsconfig.main.json && electron .",
    "build": "tsc && vite build",
    "build:all": "bash scripts/build-ci.sh --platform all",
    "build:win": "bash scripts/build-ci.sh --platform win",
    "build:mac": "bash scripts/build-ci.sh --platform mac",
    "build:linux": "bash scripts/build-ci.sh --platform linux",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "postinstall": "electron-builder install-app-deps",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2"
  },
  "keywords": [
    "electron",
    "ai",
    "agent",
    "llm",
    "desktop"
  ],
  "author": "OpenCrab Team",
  "license": "MIT",
  "devDependencies": {
    "@electron/notarize": "^2.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^29.5.14",
    "@types/markdown-it": "^13.0.7",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1",
    "eslint": "^8.56.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.4.33",
    "sass-embedded": "^1.98.0",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.3.3",
    "vite": "^5.0.11",
    "vite-plugin-electron": "^0.28.2"
  },
  "dependencies": {
    "axios": "^1.6.5",
    "dotenv": "^16.3.1",
    "electron-updater": "^6.1.7",
    "fluent-ffmpeg": "^2.1.2",
    "highlight.js": "^11.9.0",
    "keytar": "^7.9.0",
    "markdown-it": "^14.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^6.21.1",
    "sharp": "^0.33.0",
    "zustand": "^4.5.0"
  },
  "build": {
    "appId": "com.opencrab.app",
    "productName": "OpenCrab",
    "icon": "assets/logo_crab_512.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity",
      "icon": "assets/logo_crab_512.png"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/logo_crab_512.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/logo_crab_512.png"
    }
  }
}
