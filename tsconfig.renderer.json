{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist/renderer",
    "module": "ESNext",
    "target": "ES2020",
    "jsx": "react-jsx",
    "lib": ["ES2020", "DOM", "DOM.Iterable"]
  },
  "include": ["src/renderer/**/*"],
  "exclude": [
    "node_modules",
    "src/renderer/**/*.test.ts",
    "src/renderer/**/*.test.tsx",
    "src/renderer/**/__tests__/**/*.ts",
    "src/renderer/**/__tests__/**/*.tsx"
  ]
}
